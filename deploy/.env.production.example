# ZIIFRA production — copy to /var/www/ziifra/.env on the server
# Never commit real secrets. Generate APP_KEY on server: php artisan key:generate

APP_NAME=ZIIFRA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.ziifra.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Europe/Belgrade

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ziifra
DB_USERNAME=ziifra
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Hostinger SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ziifra.com
MAIL_FROM_NAME="${APP_NAME}"

# Super admin (create once, then rotate password)
SUPER_ADMIN_EMAIL=admin@ziifra.com
SUPER_ADMIN_NAME="ZIIFRA Admin"
SUPER_ADMIN_PASSWORD=

BILLING_TRIAL_DAYS=14
BILLING_ALLOW_MANUAL_UPGRADE=false

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=EUR

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.ziifra.com/auth/google/callback

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

VITE_APP_NAME="${APP_NAME}"

# Optional: bypass URL shown during deploy (php artisan down)
# DEPLOY_SECRET=ziifra-deploy
