APP_NAME=ZIIFRA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Link previews (Open Graph). Use your public APP_URL in production so shared links show the logo.
# SOCIAL_DEFAULT_IMAGE=/og/ziifra-share.png
# SOCIAL_DEFAULT_DESCRIPTION=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Europe/Zurich

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database (recommended) or redis — run: php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Hostinger: smtp.hostinger.com — port 587 (TLS) or 465 (set MAIL_SCHEME=smtps)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Platform super admin (local: php artisan ziifra:grant-super-admin --create)
SUPER_ADMIN_EMAIL=admin@ziifra.com
SUPER_ADMIN_NAME="ZIIFRA Admin"
SUPER_ADMIN_PASSWORD=password

# Billing
BILLING_TRIAL_DAYS=14
# Dev only: activate plans without Stripe (ignored when STRIPE_KEY + STRIPE_SECRET are set)
BILLING_ALLOW_MANUAL_UPGRADE=false

# Stripe — all four are required for "Pay with Stripe" checkout
# Create prices in Stripe Dashboard → Products, then paste price_... IDs below
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur
# Plan prices and Stripe/PayPal IDs are configured in Admin → Plans & billing
# APP_URL must match the URL you use in the browser (e.g. http://127.0.0.1:8000)

# PayPal — API credentials only (plan IDs are in Admin → Plans & billing)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=EUR

# Google OAuth (optional — enables “Continue with Google” when set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# OpenAI — optional, enables automatic receipt scanning on expense claims
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# HTTPS / cURL — on Windows run: php artisan app:install-ca-bundle
# HTTP_CA_BUNDLE=
# HTTP_VERIFY_SSL=true
